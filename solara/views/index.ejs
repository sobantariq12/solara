<!-- ============================================================
     PROCESS SECTION
============================================================ -->
<section class="process section" id="process">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">HOW IT WORKS</span>
      <h2 class="section-heading">How We <em>Work</em></h2>
    </div>

    <div class="process-track" aria-hidden="true">
      <div class="process-line"></div>
    </div>

    <div class="process-steps">
      <!-- Step 1 -->
      <div class="process-step reveal-stagger">
        <div class="step-bg-number">01</div>
        <div class="step-icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 4 L36 36 L4 36 Z" stroke="#E8620A" stroke-width="1.5" fill="none"/>
            <circle cx="20" cy="20" r="4" stroke="#E8620A" stroke-width="1.5"/>
            <line x1="20" y1="14" x2="20" y2="10" stroke="#E8620A" stroke-width="1"/>
            <line x1="26" y1="17" x2="29" y2="14" stroke="#E8620A" stroke-width="1"/>
            <line x1="26" y1="23" x2="29" y2="26" stroke="#E8620A" stroke-width="1"/>
          </svg>
        </div>
        <h3 class="step-title">Site Survey</h3>
        <p class="step-desc">Our engineers visit your property and assess sun exposure and structural capacity.</p>
      </div>

      <!-- Step 2 -->
      <div class="process-step reveal-stagger">
        <div class="step-bg-number">02</div>
        <div class="step-icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="6" width="28" height="28" rx="2" stroke="#E8620A" stroke-width="1.5"/>
            <line x1="6" y1="14" x2="34" y2="14" stroke="#E8620A" stroke-width="1"/>
            <line x1="14" y1="6" x2="14" y2="34" stroke="#E8620A" stroke-width="1"/>
            <rect x="18" y="18" width="10" height="10" stroke="#E8620A" stroke-width="1" fill="rgba(232,98,10,0.1)"/>
          </svg>
        </div>
        <h3 class="step-title">Custom Design</h3>
        <p class="step-desc">We design a bespoke solar system tailored to your energy needs and budget.</p>
      </div>

      <!-- Step 3 -->
      <div class="process-step reveal-stagger">
        <div class="step-bg-number">03</div>
        <div class="step-icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 20 L16 28 L32 12" stroke="#E8620A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="20" cy="20" r="16" stroke="#E8620A" stroke-width="1"/>
          </svg>
        </div>
        <h3 class="step-title">Installation</h3>
        <p class="step-desc">Certified technicians install your system with zero disruption in 1–3 days.</p>
      </div>

      <!-- Step 4 -->
      <div class="process-step reveal-stagger">
        <div class="step-bg-number">04</div>
        <div class="step-icon">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="8" width="28" height="24" rx="2" stroke="#E8620A" stroke-width="1.5"/>
            <path d="M12 20 L16 16 L20 22 L24 14 L28 20" stroke="#E8620A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <line x1="6" y1="32" x2="34" y2="32" stroke="#E8620A" stroke-width="1"/>
            <path d="M16 32 L16 36" stroke="#E8620A" stroke-width="1"/>
            <path d="M24 32 L24 36" stroke="#E8620A" stroke-width="1"/>
          </svg>
        </div>
        <h3 class="step-title">Monitoring</h3>
        <p class="step-desc">Real-time performance tracking via our mobile app. Guaranteed output or we fix it.</p>
